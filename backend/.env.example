NODE_ENV=production

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=loan_management
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# Supabase Authentication (optional, for frontend-next email auth)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Admin security
ADMIN_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_ADMIN_SECRET_MIN_32_CHARS
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_ADMIN_PASSWORD

# Redis
REDIS_URL=rediss://default:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REQUIRE_REDIS=false

# Monitoring / alerts
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
ALERT_WINDOW_MS=60000
ALERT_MIN_REQUESTS=20
ALERT_5XX_RATE_PERCENT=5
ALERT_P95_MS=1200
ALERT_COOLDOWN_MS=300000
MONITOR_MAX_5XX_RATE=5
MONITOR_MAX_P95_MS=1200

# Rate limiting
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5

# Request security / payload guard
REQUEST_BODY_LIMIT=1mb
REQUEST_PARAMETER_LIMIT=200
REQUEST_MAX_DEPTH=8
REQUEST_MAX_OBJECT_KEYS=200
REQUEST_MAX_ARRAY_LENGTH=200
REQUEST_MAX_STRING_LENGTH=10000
REQUEST_MAX_QUERY_PARAMS=80

# CORS
CORS_ALLOW_VERCEL=true

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=
EMAIL_DELIVERY_MODE=queue

# SMTP (required for real password-reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aseel.sa

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_pro_plan_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_id

# WhatsApp Cloud API (customer self-service)
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_GRAPH_VERSION=v20.0
# Optional: verify x-hub-signature-256 from Meta
WHATSAPP_WEBHOOK_SECRET=

# Optional script-only credentials
PERF_SEED_PASSWORD=
PERF_SEED_OTP=123456
RLS_TEST_DB_USER=
RLS_TEST_DB_PASSWORD=
LOAD_TEST_USER_EMAIL=
LOAD_TEST_USER_PASSWORD=
LOAD_TEST_OTP=
